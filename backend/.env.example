ARXIV_SCOUT_APP_NAME=ArXiv Literature Scout
ARXIV_SCOUT_DEBUG=false

# SQLite database (relative or absolute path)
ARXIV_SCOUT_DATABASE_PATH=data/arxiv_scout.db

# Session + SSE
ARXIV_SCOUT_SESSION_TTL_DAYS=7
ARXIV_SCOUT_SSE_HEARTBEAT_SECONDS=15

# External APIs
ARXIV_SCOUT_SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
ARXIV_SCOUT_SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here
# Semantic Scholar approved key currently allows 1 request/second.
ARXIV_SCOUT_SEMANTIC_SCHOLAR_MIN_INTERVAL_SECONDS=1.1
ARXIV_SCOUT_SEMANTIC_SCHOLAR_MAX_RETRIES=3
ARXIV_SCOUT_SEMANTIC_SCHOLAR_BACKOFF_SECONDS=1.5
ARXIV_SCOUT_ARXIV_API_URL=https://export.arxiv.org/api/query
# arXiv legacy API ToU: max one request every 3 seconds, single connection.
ARXIV_SCOUT_ARXIV_MIN_INTERVAL_SECONDS=3.0
ARXIV_SCOUT_ARXIV_MAX_RETRIES=3
ARXIV_SCOUT_ARXIV_BACKOFF_SECONDS=1.5
ARXIV_SCOUT_FIRECRAWL_BASE_URL=https://api.firecrawl.dev
ARXIV_SCOUT_FIRECRAWL_API_KEY=your_firecrawl_key_here

# Discovery + analysis limits
ARXIV_SCOUT_DISCOVERY_RESULTS_PER_ANGLE=10
ARXIV_SCOUT_DISCOVERY_SHORTLIST_SIZE=12
ARXIV_SCOUT_ANALYSIS_PAPER_CAP=8

# Hugging Face Router (OpenAI-compatible)
# Model values must include provider suffix: model:provider
ARXIV_SCOUT_HF_BASE_URL=https://router.huggingface.co/v1
ARXIV_SCOUT_HF_API_KEY=your_hf_token_here
ARXIV_SCOUT_HF_PRIMARY_MODEL=openai/gpt-oss-120b:novita
ARXIV_SCOUT_HF_SECONDARY_MODEL=Qwen/Qwen3.5-9B:together

# LLM runtime defaults
ARXIV_SCOUT_LLM_TIMEOUT_SECONDS=45.0
ARXIV_SCOUT_LLM_MAX_RETRIES=2

# LangSmith / LangChain tracing (optional)
ARXIV_SCOUT_LANGSMITH_TRACING=false
ARXIV_SCOUT_LANGSMITH_API_KEY=your_langsmith_key_here
ARXIV_SCOUT_LANGSMITH_PROJECT=arxiv-literature-scout

